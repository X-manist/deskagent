# ===== 模型上游 =====
# 中国区默认推荐 GLM 5.1。配置 GLM_* 后，桌面端和本地会员后端都会优先使用 GLM。
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_API_KEY=replace-with-your-glm-key
GLM_MODEL=glm-5.1
RELAY_MODE=glm

# 可选：OpenAI/自建 Responses 原生网关。未配置 GLM_* 时才作为默认。
# OPENAI_BASE_URL=https://llmapi.debinxiang.top/v1
# OPENAI_API_KEY=replace-with-your-relay-key
# ADAPTER_MODEL=gpt-5.4-mini
# RELAY_MODE=openai

# Core is the production/default one-click profile: only the built-in desktop bridge MCP is enabled.
# Use full only for development when you want to merge agentconfig/mcp/*.toml third-party MCP examples.
DESKAGENT_MCP_PROFILE=core

# Optional: desktop mail integration
# 正式版建议由会员后台下发邮件能力；开发/内测时可用邮箱 SMTP/IMAP 授权码。
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASS=

# Optional: WeChat bridge (custom service you control)
# 未配置时，macOS 会尝试走本机微信 UI 自动化，并在首次需要时弹出辅助功能权限引导。
WECHAT_BRIDGE_URL=
WECHAT_BRIDGE_TOKEN=

# macOS 桌面/微信自动化权限提示。正式版保持 true。
DESKAGENT_PROMPT_ACCESSIBILITY=true

# DeskAgent metering/auth backend (deskagent-server). The desktop app authenticates
# the member JWT here; the backend meters tokens and forwards to the real relay.
DESKAGENT_BACKEND_URL=http://127.0.0.1:8787

# Membership/admin backend defaults.
# Admin bootstrap is only used when the database has no admin yet.
FREE_TURNS=20
ADMIN_BOOTSTRAP_USER=admin
ADMIN_BOOTSTRAP_PASS=admin123
